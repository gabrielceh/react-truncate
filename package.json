{
  "name": "@gabrielceh/react-truncate",
  "version": "1.0.0",
  "description": "A lightweight, typed React component for truncating text by number of lines, with expand/collapse support.",
  "type": "module",
  "main": "./lib/index.cjs",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "require": "./lib/index.cjs",
      "types": "./lib/index.d.ts"
    },
    "./style.css": "./lib/react-truncate.css"
  },
  "files": [
    "lib"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "lint": "eslint .",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vite-plugin-dts": "^4.5.3"
  },
  "keywords": [
    "react",
    "truncate",
    "text",
    "line-clamp",
    "component",
    "typescript"
  ],
  "license": "MIT",
  "author": {
    "name": "Gabriel Cervantes",
    "email": "gabrielcehu@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielceh/react-truncate"
  }
}